{
  "global_tools": {
    "home.get_mode": {
      "tool_name": "home.get_mode",
      "category": "query",
      "description": "查询当前家庭模式",
      "parameters": {},
      "returns": {
        "mode": "home|away|sleep|movie|child_home|visitor|security_armed|emergency",
        "updated_at": "string"
      },
      "risk_level": "low",
      "confirmation_required": false,
      "idempotent": true
    },
    "home.set_mode": {
      "tool_name": "home.set_mode",
      "category": "control",
      "description": "设置家庭模式",
      "parameters": {
        "mode": {
          "type": "string",
          "enum": ["home", "away", "sleep", "movie", "child_home", "visitor", "security_armed", "emergency"],
          "required": true,
          "description": "家庭模式"
        },
        "reason": {
          "type": "string",
          "required": false,
          "description": "设置原因"
        }
      },
      "returns": {
        "success": "boolean",
        "mode": "string"
      },
      "risk_level": "medium",
      "confirmation_required": false,
      "idempotent": true,
      "side_effects": ["可能触发多个设备联动"]
    },
    "home.get_occupancy": {
      "tool_name": "home.get_occupancy",
      "category": "query",
      "description": "查询家庭成员是否在家",
      "parameters": {
        "user_id": {
          "type": "string",
          "required": false,
          "description": "用户ID，不传则查询所有家庭成员"
        }
      },
      "returns": {
        "occupants": "array",
        "all_away": "boolean",
        "confidence": "number"
      },
      "risk_level": "low",
      "confirmation_required": false,
      "idempotent": true
    },
    "scene.activate": {
      "tool_name": "scene.activate",
      "category": "scene",
      "description": "激活一个预设家庭场景",
      "parameters": {
        "scene_id": {
          "type": "string",
          "enum": ["go_home", "leave_home", "movie", "sleep", "wake_up", "visitor", "child_home", "security_arm"],
          "required": true,
          "description": "场景ID"
        },
        "room_id": {
          "type": "string",
          "required": false,
          "description": "房间ID，可选"
        }
      },
      "returns": {
        "success": "boolean",
        "executed_actions": "array",
        "failed_actions": "array"
      },
      "risk_level": "medium",
      "confirmation_required": false,
      "idempotent": true,
      "side_effects": ["可能同时控制多个设备"]
    },
    "scene.preview": {
      "tool_name": "scene.preview",
      "category": "query",
      "description": "预览某个场景将会执行哪些设备动作",
      "parameters": {
        "scene_id": {
          "type": "string",
          "required": true,
          "description": "场景ID"
        }
      },
      "returns": {
        "actions": "array"
      },
      "risk_level": "low",
      "confirmation_required": false,
      "idempotent": true
    },
    "automation.create_rule": {
      "tool_name": "automation.create_rule",
      "category": "config",
      "description": "创建家庭自动化规则",
      "parameters": {
        "rule_name": {
          "type": "string",
          "required": true,
          "description": "规则名称"
        },
        "trigger": {
          "type": "object",
          "required": true,
          "description": "触发器配置"
        },
        "conditions": {
          "type": "array",
          "required": false,
          "description": "条件列表"
        },
        "actions": {
          "type": "array",
          "required": true,
          "description": "动作列表"
        },
        "enabled": {
          "type": "boolean",
          "required": false,
          "default": true,
          "description": "是否启用"
        }
      },
      "returns": {
        "success": "boolean",
        "rule_id": "string"
      },
      "risk_level": "medium",
      "confirmation_required": true,
      "idempotent": false
    },
    "automation.disable_rule": {
      "tool_name": "automation.disable_rule",
      "category": "config",
      "description": "禁用自动化规则",
      "parameters": {
        "rule_id": {
          "type": "string",
          "required": true,
          "description": "规则ID"
        }
      },
      "returns": {
        "success": "boolean"
      },
      "risk_level": "low",
      "confirmation_required": false,
      "idempotent": true
    },
    "automation.list_rules": {
      "tool_name": "automation.list_rules",
      "category": "query",
      "description": "查询当前家庭自动化规则",
      "parameters": {
        "enabled_only": {
          "type": "boolean",
          "required": false,
          "default": false,
          "description": "是否只返回启用的规则"
        }
      },
      "returns": {
        "rules": "array"
      },
      "risk_level": "low",
      "confirmation_required": false,
      "idempotent": true
    }
  },
