            {"event_type": "media_control", "description": "{操作}媒体", "trigger": "播放/暂停/快进"},
            {"event_type": "scene_mode", "description": "观影模式{状态}", "trigger": "一键场景"}
          ],
          "operation_probability": {
            "family_return": {"on": 0.5, "scene": 0.2},
