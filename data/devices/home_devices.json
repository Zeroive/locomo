            {"event_type": "speed_change", "description": "风速调整至{档位}", "trigger": "APP控制"},
            {"event_type": "filter_alert", "description": "滤网更换提醒", "trigger": "达到使用寿命"},
            {"event_type": "air_exchange", "description": "换气模式{模式}", "trigger": "内/外循环切换"}
          ],
          "operation_probability": {
            "family_return": {"on": 0.6, "auto": 0.4},
            "child_return": {"on": 0.5},
            "elderly_outdoor": {"on": 0.55},
            "all_leave_arm": {"off": 0.8}
          },
          "capabilities": {
            "control": ["开关", "风速档位", "内/外循环切换"],
            "query": ["PM2.5过滤效率", "滤网剩余寿命"],
