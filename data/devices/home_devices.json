            {"event_type": "ac_switch", "description": "空调{状态}", "trigger": "手动/定时/温度联动"},
            {"event_type": "mode_change", "description": "空调模式切换为{模式}", "trigger": "模式选择"},
            {"event_type": "temp_adjust", "description": "温度调整至{温度}℃", "trigger": "语音/APP控制"},
            {"event_type": "energy_save", "description": "节能模式{状态}", "trigger": "模式切换"}
          ],
          "operation_probability": {
            "male_leave_work": {"off": 0.8, "energy_save": 0.1},
            "family_return": {"on": 0.7, "temp_adjust": 0.5},
            "elderly_outdoor": {"on": 0.6, "mode_change": 0.3},
            "child_return": {"on": 0.5}
          },
          "capabilities": {
            "control": ["开关", "模式(制冷/热/除湿/送风)", "目标温度", "风速(低/中/高/自动)", "扫风方向"],
            "config": ["节能模式", "睡眠曲线", "滤网清洗提醒重置"]
