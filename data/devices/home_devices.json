          "capabilities": {
            "control": ["开合百分比(0-100%)", "暂停", "全开/全关"],
            "config": ["手拉启动灵敏度", "定时开合（如早晨7点自动开30%）"]
          },
          "state_transitions": {
            "open": ["closing", "closed"],
            "closed": ["opening", "open"],
            "opening": ["open", "stopped"],
            "closing": ["closed", "stopped"]
          },
          "data_types": ["timestamp", "position", "direction", "speed"]
        },
        "fresh_air_system": {
          "name": "新风系统",
          "description": "室内外空气交换与净化",
          "scenarios": ["family_return", "child_return", "elderly_outdoor", "all_leave_arm"],
          "typical_events": [
