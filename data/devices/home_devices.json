          "operation_probability": {
            "male_leave_work": {"off": 0.95, "on": 0.05},
            "child_return": {"on": 0.9, "brightness": 0.5},
            "family_return": {"on": 0.85, "scene": 0.4},
            "visitor_arrival": {"on": 0.9, "brightness": 0.3}
          },
          "capabilities": {
            "control": ["开关", "亮度(0-100%)", "色温(2700K-6500K)"],
            "config": ["渐变过渡时间(ms)", "定时/倒计时", "生物钟节律模式"]
          },
          "state_transitions": {
            "off": ["on"],
            "on": ["off", "dimmed", "color_changed"],
            "dimmed": ["bright", "off"]
          },
          "data_types": ["timestamp", "power_state", "brightness", "color_temp", "scene_id"]
        },
        "air_conditioner": {
          "name": "空调",
          "description": "室内温度调节",
          "scenarios": ["male_leave_work", "family_return", "elderly_outdoor", "child_return"],
