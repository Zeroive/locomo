          "name": "智能窗帘",
          "description": "控制自然光与隐私",
          "scenarios": ["male_leave_work", "family_return", "child_return", "visitor_arrival"],
          "typical_events": [
            {"event_type": "curtain_move", "description": "窗帘{操作}", "trigger": "手动/定时/光照联动"},
            {"event_type": "curtain_stop", "description": "窗帘暂停", "trigger": "手动控制"},
            {"event_type": "scene_linkage", "description": "窗帘联动{场景}", "trigger": "场景触发"}
