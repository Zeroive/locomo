{
  "device_categories": {
    "sensing_devices": {
      "name": "感知类设备",
      "description": "用于感知和检测环境及人员状态的设备",
      "devices": {
        "wifi_router": {
          "name": "WiFi AP / 路由器",
          "description": "用于检测家庭成员手机、手表等终端上线",
          "scenarios": ["male_leave_work", "family_return", "all_leave_arm", "anomaly_detection"],
          "typical_events": [
            {"event_type": "device_online", "description": "{设备名称}上线", "trigger": "手机连接WiFi"},
            {"event_type": "device_offline", "description": "{设备名称}离线", "trigger": "手机离开WiFi覆盖范围"},
            {"event_type": "network_block", "description": "设备{设备名称}被踢出网络", "trigger": "家长控制操作"},
            {"event_type": "guest_network", "description": "访客网络{状态}", "trigger": "开启/关闭访客网络"}
          ],
          "operation_probability": {
            "male_leave_work": {"online": 0.05, "offline": 0.95},
            "family_return": {"online": 0.95, "offline": 0.05},
            "all_leave_arm": {"online": 0.05, "offline": 0.95},
            "anomaly_detection": {"unusual_device": 0.1}
          },
          "capabilities": {
            "query": ["连接设备列表", "MAC地址", "RSSI信号强度", "在线状态"],
            "control": ["踢出设备", "开启/关闭访客网络", "儿童上网时间段限制"],
            "config": ["设备别名绑定", "回家/离家地理围栏触发阈值"]
          },
          "state_transitions": {
            "online": ["offline"],
            "offline": ["online"],
            "blocked": ["unblocked"]
          },
          "data_types": ["device_id", "timestamp", "rssi", "connection_duration"]
        },
        "door_camera": {
          "name": "门口摄像头",
          "description": "用于检测门口有人靠近",
          "scenarios": ["visitor_arrival", "anomaly_detection", "family_return", "all_leave_arm"],
          "typical_events": [
            {"event_type": "motion_detected", "description": "检测到门口移动", "trigger": "人形进入监控区域"},
            {"event_type": "face_recognized", "description": "识别到{人名}", "trigger": "人脸匹配成功"},
            {"event_type": "snapshot", "description": "摄像头抓拍", "trigger": "手动/自动触发"},
            {"event_type": "two_way_audio", "description": "双向对讲{状态}", "trigger": "发起/结束对讲"},
            {"event_type": "intrusion_alert", "description": "逗留报警", "trigger": "超过逗留阈值"}
          ],
          "operation_probability": {
            "visitor_arrival": {"motion": 1.0, "face_recognized": 0.7},
            "anomaly_detection": {"motion": 0.3, "intrusion": 0.1},
            "family_return": {"motion": 0.95, "face_recognized": 0.9},
            "all_leave_arm": {"motion": 0.1, "intrusion": 0.05}
          },
          "capabilities": {
            "control": ["抓拍", "录制短视频", "开启双向对讲", "播放预设语音"],
            "query": ["当前画面流", "最近一次移动侦测时间"],
            "config": ["人形检测灵敏度", "逗留报警时间阈值", "人脸库白名单比对"]
          },
          "state_transitions": {
            "idle": ["motion_detected"],
            "motion_detected": ["face_recognized", "intrusion_alert", "idle"],
            "recording": ["idle"]
          },
          "data_types": ["timestamp", "motion_type", "face_id", "image_url", "duration"]
        },
        "smart_lock": {
          "name": "智能门锁",
          "description": "开锁、锁门、指纹开锁、关门",
          "scenarios": ["male_leave_work", "family_return", "all_leave_arm", "visitor_arrival"],
          "typical_events": [
            {"event_type": "lock_unlock", "description": "门锁{操作}", "trigger": "指纹/密码/远程解锁"},
            {"event_type": "door_status", "description": "门{状态}", "trigger": "开门/关门/虚掩"},
            {"event_type": "temp_password", "description": "生成临时密码", "trigger": "创建一次性/周期密码"},
            {"event_type": "tamper_alert", "description": "防撬报警", "trigger": "异常开锁尝试"}
          ],
          "operation_probability": {
            "male_leave_work": {"lock": 0.95, "unlock": 0.05},
            "family_return": {"unlock": 0.95, "lock": 0.05},
            "all_leave_arm": {"lock": 1.0, "auto_lock": 0.9},
            "visitor_arrival": {"temp_password": 0.5, "remote_unlock": 0.3}
          },
          "capabilities": {
            "control": ["远程解锁（需二次确认）", "关门自动落锁"],
            "query": ["当前电量", "门状态（开/关/虚掩）", "开锁日志（谁在何时用什么方式）"],
            "config": ["生成临时密码（一次性/周期/限时）", "下发指纹/IC卡", "防撬报警开关"]
          },
          "state_transitions": {
            "locked": ["unlocked"],
            "unlocked": ["locked", "door_open"],
            "door_open": ["door_closed", "locked"],
            "low_battery": ["normal"]
          },
          "data_types": ["timestamp", "operation_type", "user_id", "method", "battery_level"]
        }
      }
    },
    "environmental_sensors": {
      "name": "环境感知设备",
      "description": "监测室内环境参数的传感器",
      "devices": {
        "temp_humidity_sensor": {
          "name": "温湿度传感器",
          "description": "监测室内冷暖干湿",
          "scenarios": ["male_leave_work", "family_return", "elderly_outdoor", "child_return"],
          "typical_events": [
            {"event_type": "temp_threshold", "description": "温度{状态}", "trigger": "超过高低温阈值"},
            {"event_type": "humidity_threshold", "description": "湿度{状态}", "trigger": "超过高低湿阈值"},
            {"event_type": "climate_alert", "description": "舒适度提醒", "trigger": "温湿度组合触发"}
          ],
          "operation_probability": {
            "male_leave_work": {"read": 0.3},
            "family_return": {"read": 0.5},
            "elderly_outdoor": {"alert": 0.2},
            "child_return": {"read": 0.2}
          },
          "capabilities": {
            "query": ["当前温度(℃)", "当前湿度(%)"],
            "config": ["温度/湿度高低阈值报警", "数据采样上报频率"]
          },
          "state_transitions": {
            "normal": ["temp_high", "temp_low", "humidity_high", "humidity_low"],
            "temp_high": ["normal"],
            "temp_low": ["normal"]
          },
          "data_types": ["timestamp", "temperature", "humidity", "comfort_level"]
        },
        "light_sensor": {
          "name": "光照传感器",
          "description": "监测环境亮度",
          "scenarios": ["child_return", "family_return", "male_leave_work"],
          "typical_events": [
            {"event_type": "light_change", "description": "光照强度变化", "trigger": "亮度超过阈值"},
            {"event_type": "dark_trigger", "description": "暗光触发", "trigger": "低于设定亮度"}
          ],
          "operation_probability": {
            "child_return": {"dark_trigger": 0.6},
            "family_return": {"dark_trigger": 0.7},
            "male_leave_work": {"light_change": 0.3}
          },
          "capabilities": {
            "query": ["光照度(Lux)"],
            "config": ["暗光触发阈值（如低于50 Lux联动开灯）"]
          },
          "state_transitions": {
            "bright": ["dim", "dark"],
            "dim": ["bright", "dark"],
            "dark": ["dim", "bright"]
          },
          "data_types": ["timestamp", "lux", "trigger_status"]
        },
        "air_quality_sensor": {
          "name": "空气质量传感器",
          "description": "监测PM2.5、CO2、甲醛/TVOC",
          "scenarios": ["family_return", "elderly_outdoor", "child_return", "all_leave_arm"],
          "typical_events": [
            {"event_type": "pm25_alert", "description": "PM2.5超标", "trigger": "浓度超过标准"},
            {"event_type": "co2_alert", "description": "CO2浓度过高", "trigger": "超过1500ppm"},
            {"event_type": "tvoc_alert", "description": "TVOC超标", "trigger": "空气质量等级变化"}
          ],
          "operation_probability": {
            "family_return": {"read": 0.4, "alert": 0.1},
            "elderly_outdoor": {"alert": 0.15},
            "child_return": {"read": 0.2},
            "all_leave_arm": {"monitor": 0.5}
          },
          "capabilities": {
            "query": ["PM2.5浓度", "CO2 ppm", "TVOC等级"],
            "config": ["超标联动阈值（如CO2>1500联动新风系统）"]
          },
          "state_transitions": {
            "good": ["moderate", "poor"],
            "moderate": ["good", "poor"],
            "poor": ["moderate", "good"]
          },
          "data_types": ["timestamp", "pm25", "co2", "tvoc", "aqi"]
        }
      }
    },
    "actuators": {
      "name": "执行设备",
      "description": "用于执行特定动作或控制的设备",
      "devices": {
        "smart_light": {
          "name": "智能灯",
          "description": "照明及氛围营造",
          "scenarios": ["male_leave_work", "child_return", "family_return", "visitor_arrival"],
          "typical_events": [
            {"event_type": "light_switch", "description": "{灯名称}{状态}", "trigger": "手动/定时/联动"},
            {"event_type": "brightness_change", "description": "{灯名称}亮度调整", "trigger": "语音/APP控制"},
            {"event_type": "color_temp", "description": "{灯名称}色温调整", "trigger": "场景模式切换"},
            {"event_type": "scene_activate", "description": "灯光场景{场景名称}激活", "trigger": "模式选择"}
